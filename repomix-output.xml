  "Ramesh Kumar": 78,
  "Kavitha Reddy": 82,
  "Prakash N": 52,
  "Manjunath S": 45,
  "Suresh Gowda": 18
};

seededFarmers.forEach(f => {
  const score = calculateDistressScore(f);
  const status = getDistressStatus(score);
  const expected = expectedScores[f.name];
  const passed = score === expected;
