        <div className="p-6 bg-white/[0.02] border-t border-white/5">
           <div className="flex items-center gap-3 mb-4">
              <div className="w-2 h-2 rounded-full bg-teal-500 animate-pulse shadow-[0_0_8px_#14b8a6]" />
